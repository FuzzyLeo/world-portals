{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeDigest",
    ":automergeMinor"
  ],
  "automergeType": "branch",
  "forkProcessing": "enabled",
  "pinDigest": {
    "automerge": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+ref: (?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["AmyJeanes/gmod-addon-tools"],
      "automerge": false
    }
  ]
}
